# Deploy script configuration. Copy this file to .env before deploying.

# RPC endpoint for the network you are deploying to (must change for mainnet deployment)
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Signing: The deploy script reads PRIVATE_KEY from this file by default.
# WARNING: Storing private keys in files is a security risk. Use this for testnet deployments and if you know what you are doing. For mainnet, best use a more secure way of passing the private key (as detailed below).
PRIVATE_KEY=0x...

# Safer alternatives (pass directly to forge instead):
#   forge script script/Deploy.s.sol --ledger          (hardware wallet)
#   forge script script/Deploy.s.sol --trezor          (hardware wallet)
#   forge script script/Deploy.s.sol --account mykey   (encrypted keystore via cast wallet)
#   forge script script/Deploy.s.sol --interactive     (prompts for private key at runtime)

# Deployed contract addresses (replace with your own after deployment)
BVSTOKEN_ADDRESS=0x96121f09D322135A60D87fc47F62d4F9e9D881BF
BVSREGISTRY_ADDRESS=0x6475f6DFB75822B2e1B38966Ab4B38aca6703aC6

# Snapshot
SNAPSHOT_SPACE=
SNAPSHOT_HUB=https://testnet.hub.snapshot.org

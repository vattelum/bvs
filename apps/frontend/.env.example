# Demo BVS deployed on Sepolia testnet. Copy this file to .env to see this app in action with a test deployment.
# To use your own deployment, replace the values below after running your deploy script.

# Your deployed BVSToken contract address (e.g., 0x9612...)
VITE_BVS_TOKEN_ADDRESS=0x96121f09D322135A60D87fc47F62d4F9e9D881BF

# Your deployed BVSRegistry contract address (e.g., 0x6475...)
VITE_BVS_REGISTRY_ADDRESS=0x6475f6DFB75822B2e1B38966Ab4B38aca6703aC6

# Chain ID: 11155111 for Sepolia, 1 for Ethereum mainnet
VITE_CHAIN_ID=11155111

# Block number when contracts were deployed (speeds up event log scanning)
VITE_DEPLOY_BLOCK=10426220

# Public RPC endpoint for your target network (you can use a public one, or something like Infura/Alchemy)
VITE_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Snapshot space name (e.g., bvs.eth)
VITE_SNAPSHOT_SPACE=bvs.eth

# Snapshot hub URL: https://testnet.hub.snapshot.org for testnet, https://hub.snapshot.org for production
VITE_SNAPSHOT_HUB=https://testnet.hub.snapshot.org

# Arweave uploads use the connected wallet via ArDrive Turbo. No private key needed — the admin signs uploads through their wallet.
